# ============================================================
# AUFlow – Production Environment Template
# Copy to .env on the server and fill in every value.
# NEVER commit .env to version control.
# ============================================================

APP_NAME=AUFlow
APP_ENV=production
APP_KEY=                          # REQUIRED – generate with: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://yourdomain.com    # Set to your actual domain (https:// in production)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# ---- Logging -----------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ---- Database ----------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1                 # Adjust to your MySQL server host
DB_PORT=3306
DB_DATABASE=auflow
DB_USERNAME=auflow
DB_PASSWORD=                      # REQUIRED – strong random password

# ---- Session -----------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true              # Encrypt session data at rest
SESSION_PATH=/
SESSION_DOMAIN=yourdomain.com     # REQUIRED – your domain (no https://)

# ---- Broadcasting / Filesystem / Queue ---------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# ---- Cache -------------------------------------------------
CACHE_STORE=redis
CACHE_PREFIX=auflow

# ---- Redis -------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1              # Adjust to your Redis server host
REDIS_PASSWORD=                   # REQUIRED – strong random password
REDIS_PORT=6379

# ---- Mail --------------------------------------------------
MAIL_MAILER=resend
RESEND_API_KEY=                   # REQUIRED
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="AUFlow"

# ---- Workflow ----------------------------------------------
WORKFLOW_REMINDER_DELAYS=1d,2d,3d
WORKFLOW_REMINDER_DEFAULT_INTERVAL=1d
WORKFLOW_REMINDER_TIME=09:00

# ---- Security keys (REQUIRED – generate unique values) ----
# Snapshot HMAC: openssl rand -base64 32
SNAPSHOT_SIGNING_KEY=             # REQUIRED

# PAYLOAD_ENCRYPTION_KEY has been removed — submission payloads are stored as plain JSON.
# Access is controlled at the database level.

SNAPSHOT_ALLOW_LEGACY_HASH_VERIFICATION=false
SNAPSHOT_STORAGE_DISK=local

# ---- AWS (only if using S3 for file storage) ---------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
